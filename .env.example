# Environment Configuration for Mental Health Chatbot

# Node Environment
NODE_ENV=development
PORT=4000

# ========== DATABASE CONFIGURATION ==========
DATABASE_URL=postgresql://postgres:password@localhost:5432/mental_health_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=mental_health_db

# ========== REDIS CONFIGURATION ==========
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ========== JWT CONFIGURATION ==========
JWT_SECRET=your_super_secret_jwt_key_change_in_production_immediately
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_jwt_key
JWT_REFRESH_EXPIRE=30d

# ========== OPENAI API CONFIGURATION ==========
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# ========== FRONTEND & BACKEND URLS ==========
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# ========== EMAIL CONFIGURATION ==========
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ========== NLP SERVICE CONFIGURATION ==========
NLP_SERVICE_URL=http://localhost:5000

# ========== CRISIS DETECTION CONFIGURATION ==========
CRISIS_DETECTION_ENABLED=true
CRISIS_DETECTION_THRESHOLD=0.8
CRISIS_HOTLINE_1=1-800-273-8255
CRISIS_HOTLINE_2=741741
CRISIS_HOTLINE_NAME_1=National Suicide Prevention Lifeline
CRISIS_HOTLINE_NAME_2=Crisis Text Line

# ========== LOGGING CONFIGURATION ==========
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=logs/app.log

# ========== SESSION CONFIGURATION ==========
SESSION_SECRET=your_session_secret_key
SESSION_TIMEOUT=3600000

# ========== CORS CONFIGURATION ==========
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ========== RATE LIMITING CONFIGURATION ==========
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ========== FILE UPLOAD CONFIGURATION ==========
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=pdf,doc,docx,txt

# ========== AWS CONFIGURATION (Optional) ==========
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ========== STRIPE CONFIGURATION (Optional) ==========
STRIPE_PUBLIC_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_

# ========== SENTRY CONFIGURATION (Error Tracking) ==========
SENTRY_DSN=

# ========== TWILIO CONFIGURATION (SMS Support) ==========
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
